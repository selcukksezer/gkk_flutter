{"_tag":"Help","doc":{"description":"Manage Postgres databases.","usage":"supabase db <subcommand> [flags]","flags":[],"annotations":{"_id":"Context","services":[]},"subcommands":[{"commands":[{"name":"diff","shortDescription":"Diffs the local database for schema changes","description":"Diffs the local database for schema changes."},{"name":"dump","shortDescription":"Dumps data or schemas from the remote database","description":"Dumps data or schemas from the remote database."},{"name":"push","shortDescription":"Push new migrations to the remote database","description":"Push new migrations to the remote database."},{"name":"pull","shortDescription":"Pull schema from the remote database","description":"Pull schema from the remote database."},{"name":"reset","shortDescription":"Resets the local database to current migrations","description":"Resets the local database to current migrations."},{"name":"lint","shortDescription":"Checks local database for typing error","description":"Checks local database for typing error."},{"name":"start","shortDescription":"Starts local Postgres database","description":"Starts local Postgres database."},{"name":"query","shortDescription":"Execute a SQL query against the database","description":"Execute a SQL query against the database."},{"name":"advisors","shortDescription":"Checks database for security and performance issues","description":"Checks database for security and performance issues."},{"name":"schema","shortDescription":"Manage database schema","description":"Manage database schema."}]}],"globalFlags":[{"name":"help","aliases":["-h"],"type":"boolean","description":{"_id":"Option","_tag":"Some","value":"Show help information"},"required":false},{"name":"version","aliases":["-v"],"type":"boolean","description":{"_id":"Option","_tag":"Some","value":"Show version information"},"required":false},{"name":"completions","aliases":[],"type":"choice","description":{"_id":"Option","_tag":"Some","value":"Print shell completion script (c